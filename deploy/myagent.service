[Unit]
Description=myagent - AI Quant Trading Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=myagent
Group=myagent
WorkingDirectory=/opt/myagent
ExecStart=/usr/local/bin/bun run /opt/myagent/dist/main.js
Restart=always
RestartSec=10
StartLimitBurst=5
StartLimitIntervalSec=300

# Environment
EnvironmentFile=/opt/myagent/.env
Environment=NODE_ENV=production

# Resource limits
MemoryMax=2G
CPUQuota=200%

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/myagent/data /opt/myagent/logs

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=myagent

[Install]
WantedBy=multi-user.target
